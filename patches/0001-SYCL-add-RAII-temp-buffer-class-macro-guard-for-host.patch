     const int nblocks = size / sizeof(block_q6_K);
 
-    bool host_fallback = false;
-    uint8_t * tmp_buf = static_cast<uint8_t *>(sycl_ext_malloc_with_fallback(stream, size, host_fallback));
-    if (!tmp_buf) {
